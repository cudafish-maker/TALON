#!/bin/sh
set -eu

zero_sha=0000000000000000000000000000000000000000
blocked_paths_file=$(mktemp)
trap 'rm -f "$blocked_paths_file"' EXIT HUP INT TERM

while read -r local_ref local_sha remote_ref remote_sha
do
    if [ -z "${local_ref:-}" ] || [ "$local_sha" = "$zero_sha" ]; then
        continue
    fi

    local_commit=$(git rev-parse -q --verify "$local_sha^{commit}" 2>/dev/null || true)
    if [ -z "$local_commit" ]; then
        continue
    fi

    commits=$(git rev-list "$local_commit" --not --remotes)

    for commit in $commits
    do
        git diff-tree --root --no-commit-id --name-status -r "$commit" |
            awk '
                {
                    status = substr($1, 1, 1)
                    for (i = 2; i <= NF; i++) {
                        path = tolower($i)
                        allowed = (path == "readme-install.md")
                        if (path ~ /\.(md|html)$/ && status != "D" && !allowed) {
                            print $i
                        }
                    }
                }
            ' >> "$blocked_paths_file"
    done
done

if [ -s "$blocked_paths_file" ]; then
    {
        echo "TALON policy: Markdown and HTML files may be committed locally, but must not be pushed to a remote."
        echo
        echo "This push contains local-only paths:"
        sort -u "$blocked_paths_file" | sed 's/^/  - /'
        echo
        echo "Split or amend the pushed commits so Markdown and HTML changes stay local."
    } >&2
    exit 1
fi

exit 0
