#!/usr/bin/env bash
set -euo pipefail

zero_sha=0000000000000000000000000000000000000000
repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)

# shellcheck source=../../tools/talon-publish-policy.sh
. "$repo_root/tools/talon-publish-policy.sh"

blocked_paths_file=$(mktemp)
tag_errors_file=$(mktemp)
branch_errors_file=$(mktemp)
trap 'rm -f "$blocked_paths_file" "$tag_errors_file" "$branch_errors_file"' EXIT HUP INT TERM

while read -r local_ref local_sha remote_ref remote_sha
do
    case "$remote_ref" in
        refs/heads/dev|refs/heads/main|refs/tags/*)
            ;;
        refs/heads/*)
            echo "$remote_ref" >> "$branch_errors_file"
            ;;
    esac

    if [ -z "${local_ref:-}" ] || [ "$local_sha" = "$zero_sha" ]; then
        continue
    fi

    local_commit=$(git rev-parse -q --verify "$local_sha^{commit}" 2>/dev/null || true)
    if [ -z "$local_commit" ]; then
        continue
    fi

    case "$remote_ref" in
        refs/tags/v*)
            version=${remote_ref#refs/tags/v}
            if ! git cat-file -e "$local_commit:CHANGELOG.md" 2>/dev/null; then
                echo "$remote_ref requires CHANGELOG.md at the tagged commit." >> "$tag_errors_file"
            elif ! git show "$local_commit:CHANGELOG.md" | grep -Fq "## [$version] - "; then
                echo "$remote_ref requires a CHANGELOG.md section: ## [$version] - YYYY-MM-DD" >> "$tag_errors_file"
            fi
            ;;
    esac

    while IFS= read -r commit
    do
        while IFS= read -r -d '' path
        do
            if talon_is_blocked_remote_path "$path"; then
                printf '%s\n' "$path" >> "$blocked_paths_file"
            fi
        done < <(git diff-tree --root --no-commit-id --name-only --no-renames -r -z "$commit")
    done < <(git rev-list "$local_commit" --not --remotes)
done

if [ -s "$tag_errors_file" ]; then
    {
        echo "TALON release policy: version tags must include a matching CHANGELOG.md entry."
        echo
        sort -u "$tag_errors_file" | sed 's/^/  - /'
    } >&2
    exit 1
fi

if [ -s "$branch_errors_file" ]; then
    {
        echo "TALON branch policy: only dev and main may be pushed to remote."
        echo "local-docs stays local-only."
        echo
        echo "This push targets blocked branch refs:"
        sort -u "$branch_errors_file" | sed 's/^/  - /'
    } >&2
    exit 1
fi

if [ -s "$blocked_paths_file" ]; then
    {
        talon_print_publish_policy
        echo
        echo "This push contains blocked paths:"
        sort -u "$blocked_paths_file" | sed 's/^/  - /'
        echo
        echo "Use tools/promote-local-docs-release.sh to publish a clean dev/main tip."
    } >&2
    exit 1
fi

exit 0
