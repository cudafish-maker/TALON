#:kivy 2.0
#:import theme talon.ui.theme
#:import dp kivy.metrics.dp

<LoginScreen>:
    MDBoxLayout:
        orientation: "vertical"
        padding: "32dp"
        spacing: "32dp"
        pos_hint: {"center_x": .5, "center_y": .5}
        size_hint: .7, None
        height: self.minimum_height

        MDLabel:
            id: title_label
            text: "T.A.L.O.N."
            halign: "center"
            font_style: "Display"
            role: "small"
            size_hint_x: 1
            text_size: self.width, None # takes full width of the parent

        MDLabel:
            id: subtitle_label
            text: "Tactical Awareness & Linked Operations Network"
            halign: "center"
            font_style: "Body"
            role: "small"

        MDTextField:
            id: passphrase_field
            password: True
            mode: "outlined"

            MDTextFieldHintText:
                id: passphrase_hint
                text: "Passphrase"

        MDTextField:
            id: confirm_passphrase_field
            password: True
            mode: "outlined"
            disabled: not root.initial_setup
            opacity: 1 if root.initial_setup else 0
            size_hint_y: None
            height: dp(64) if root.initial_setup else 0

            MDTextFieldHintText:
                text: "Confirm passphrase"

        MDLabel:
            id: requirements_label
            text: root.passphrase_requirements if root.initial_setup else ""
            halign: "left"
            valign: "middle"
            font_style: "Body"
            role: "small"
            theme_text_color: "Secondary"
            text_size: self.width, None
            size_hint_y: None
            height: dp(96) if root.initial_setup else 0

        MDButton:
            id: unlock_button
            style: "elevated"
            pos_hint: {"center_x": .5}
            on_release: root.on_login_pressed(passphrase_field.text, confirm_passphrase_field.text)

            MDButtonText:
                id: unlock_button_text
                text: "UNLOCK"

        MDLabel:
            id: error_label
            text: ""
            halign: "center"
            theme_text_color: "Error"
