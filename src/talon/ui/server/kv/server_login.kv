# kv/server_login.kv
# Server login screen layout.
# Same structure as client login but uses amber accent (server = "the chair").

<ServerLoginScreen>:
    md_bg_color: app.theme_cls.backgroundColor

    MDBoxLayout:
        orientation: "vertical"
        padding: "32dp"

        Widget:
            size_hint_y: 0.25

        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: self.minimum_height
            spacing: "8dp"
            padding: [0, 0, 0, "32dp"]

            MDLabel:
                text: "T.A.L.O.N."
                halign: "center"
                font_style: "Headline"
                role: "medium"
                bold: True
                theme_text_color: "Custom"
                text_color: "#f5a623"
                size_hint_y: None
                height: self.texture_size[1]

            MDLabel:
                text: "SERVER — THE CHAIR"
                halign: "center"
                font_style: "Label"
                role: "small"
                theme_text_color: "Custom"
                text_color: "#f5a623"
                size_hint_y: None
                height: self.texture_size[1]

            MDLabel:
                text: "Tactical Awareness & Linked Operations Network"
                halign: "center"
                font_style: "Body"
                role: "small"
                theme_text_color: "Custom"
                text_color: "#8a9bb0"
                size_hint_y: None
                height: self.texture_size[1]

        MDCard:
            orientation: "vertical"
            padding: "24dp"
            spacing: "16dp"
            size_hint: None, None
            size: min(root.width - 64, 400), self.minimum_height
            pos_hint: {"center_x": 0.5}
            md_bg_color: "#151d2b"
            radius: [8, 8, 8, 8]

            MDLabel:
                text: "SERVER OPERATOR LOGIN"
                font_style: "Label"
                role: "small"
                theme_text_color: "Custom"
                text_color: "#8a9bb0"
                size_hint_y: None
                height: self.texture_size[1]

            MDTextField:
                id: passphrase_field
                hint_text: "Server passphrase"
                password: True
                mode: "rectangle"
                line_color_focus: "#f5a623"
                text_color_focus: "#e8edf4"
                hint_text_color_normal: "#3d4f63"
                fill_color_normal: "#0f1520"
                fill_color_focus: "#0f1520"
                on_text: root.on_passphrase_text(self, self.text)
                on_text_validate: root.on_submit()

            MDLabel:
                text: root.error_text
                theme_text_color: "Custom"
                text_color: "#ff3b3b"
                font_style: "Body"
                role: "small"
                size_hint_y: None
                height: self.texture_size[1] if root.error_text else 0
                opacity: 1 if root.error_text else 0

            MDButton:
                text: "STARTING SERVER..." if root.is_loading else "START SERVER"
                disabled: root.is_loading
                on_release: root.on_submit()
                md_bg_color: "#f5a623" if not root.is_loading else "#1c2637"
                theme_text_color: "Custom"
                text_color: "#0a0e14" if not root.is_loading else "#3d4f63"
                size_hint_x: 1
                height: "48dp"
                bold: True

        Widget:
            size_hint_y: 0.3

        MDLabel:
            text: "Authorized personnel only — all actions are audited"
            halign: "center"
            font_style: "Body"
            role: "small"
            theme_text_color: "Custom"
            text_color: "#3d4f63"
            size_hint_y: None
            height: self.texture_size[1]
